{
  "name": "adbridge",
  "version": "1.2.3",
  "description": "Android device management via ADB",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node tests/updater.test.js && node tests/manual-updater.test.js && node tests/app-info.test.js && node tests/runner.test.js && node tests/device.test.js && node tests/files.test.js && node tests/packages.test.js && node tests/adb-routes.test.js && node tests/runtime-paths.test.js && node tests/explorer-action-state.test.mjs && node tests/explorer-rename.test.mjs && node tests/version-placement.test.js && node tests/explorer-go-removal.test.js && node tests/build-config.test.js",
    "build": "npm run build:dir",
    "build:dir": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win dir"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.3.0",
    "electron-builder": "^24.13.0",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.adbridge.app",
    "productName": "ADBridge",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "afterPack": "scripts/after-pack.js",
    "files": [
      "src/**/*",
      "assets/icon.ico"
    ],
    "extraFiles": [
      {
        "from": "vendor/scrcpy",
        "to": "scrcpy",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/LICENSES",
        "to": "LICENSES",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "docs/THIRD_PARTY_LICENSES.md",
        "to": "THIRD_PARTY_LICENSES.md"
      },
      {
        "from": "build/README.txt",
        "to": "README.txt"
      }
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ]
  }
}
